---
name: chat
description: A basic chat prompt for GPT-4o realtime interactions.
authors:
  - ngrassetto
model:
  api: chat
  configuration:
    type: azure_openai
    azure_deployment: gpt-4o
  parameters:
    max_tokens: 1024
    temperature: 0.7
sample:
  question: "Hello, how can you help me today?"
---

system:
You are a helpful AI assistant.

user:
{{question}}
